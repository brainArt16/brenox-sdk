{
  "name": "@brenox/react",
  "version": "0.1.1",
  "description": "React hooks for the Brenox TypeScript SDK",
  "homepage": "https://brenox-web.vercel.app/docs?sdk=react&v=0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brainArt16/brenox-sdk.git",
    "directory": "react"
  },
  "bugs": {
    "url": "https://github.com/brainArt16/brenox-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@brenox/sdk": ">=0.1.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@brenox/sdk": "file:..",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MIT"
}
