{
  "name": "@brenox/sdk",
  "version": "0.1.3",
  "description": "TypeScript SDK for the Brenox realtime communication platform",
  "homepage": "https://www.breno-x.com/docs?sdk=typescript&v=0.1.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brainArt16/brenox-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/brainArt16/brenox-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server-entry.d.ts",
        "default": "./dist/server-entry.js"
      },
      "require": {
        "types": "./dist/server-entry.d.cts",
        "default": "./dist/server-entry.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:all": "npm run build && npm run build --workspace @brenox/react",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:all": "npm test && npm test --workspace @brenox/react",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "keywords": [
    "brenox",
    "chat",
    "websocket",
    "sdk"
  ],
  "license": "MIT",
  "workspaces": [
    "react"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  }
}
